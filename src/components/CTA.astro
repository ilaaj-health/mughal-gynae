---
import { site, waLink } from "../data/site";
interface Props {
  title?: string;
  text?: string;
}
const {
  title = "Ready to book your appointment?",
  text = "Speak with our team today — call us directly or send a message on WhatsApp and we'll help you find the right specialist and a time that suits you.",
} = Astro.props;
---

<section class="relative overflow-hidden bg-ink py-16 text-white sm:py-20">
  <div class="dot-grid absolute inset-0 opacity-10"></div>
  <div class="pointer-events-none absolute -bottom-24 -left-16 h-72 w-72 rounded-full bg-maroon-700/40 blur-3xl"></div>
  <div class="pointer-events-none absolute -top-24 right-0 h-72 w-72 rounded-full bg-gold-500/15 blur-3xl"></div>

  <div class="reveal relative mx-auto w-[92%] max-w-[820px] text-center">
    <span class="gold-rule mx-auto mb-5 block"></span>
    <h2 class="font-display text-3xl font-bold leading-tight text-white sm:text-[40px]">{title}</h2>
    <p class="mx-auto mt-4 max-w-xl text-[17px] text-white/70">{text}</p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a href={site.phoneHref} class="shine inline-flex items-center gap-2.5 rounded-full bg-gold-500 px-7 py-3.5 font-semibold text-ink transition hover:-translate-y-0.5 hover:bg-gold-400">
        <i class="fa-solid fa-phone"></i> Call {site.phoneDisplay}
      </a>
      <a href={waLink("Hello! I would like to book an appointment at Mughal Gynae.")} target="_blank" rel="noopener" class="inline-flex items-center gap-2.5 rounded-full bg-[#25D366] px-7 py-3.5 font-semibold text-white transition hover:-translate-y-0.5 hover:bg-[#1ebe5b]">
        <i class="fa-brands fa-whatsapp text-lg"></i> WhatsApp Us
      </a>
    </div>
  </div>
</section>
