---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: "center" | "left";
  light?: boolean;
}
const { eyebrow, title, subtitle, align = "center", light = false } = Astro.props;
const center = align === "center";
---

<div class:list={["reveal", center ? "mx-auto max-w-2xl text-center" : "max-w-2xl"]}>
  {eyebrow && (
    <span class:list={["eyebrow", light ? "text-gold-300" : "text-maroon-700"]}>{eyebrow}</span>
  )}
  <div class:list={["mb-4 mt-3", center && "flex justify-center"]}>
    <span class="gold-rule"></span>
  </div>
  <h2 class:list={["font-display text-3xl font-bold leading-tight sm:text-4xl lg:text-[42px]", light ? "text-white" : "text-ink"]}>
    {title}
  </h2>
  {subtitle && (
    <p class:list={["mt-4 text-[17px] leading-relaxed", light ? "text-maroon-100/80" : "text-[#6b5a61]"]}>
      {subtitle}
    </p>
  )}
</div>
