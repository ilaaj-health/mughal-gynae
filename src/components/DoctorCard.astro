---
import type { Doctor } from "../data/doctors";
import { initials } from "../data/doctors";
import { site, waLink } from "../data/site";
interface Props {
  doctor: Doctor;
  delay?: string;
}
const { doctor, delay = "" } = Astro.props;
const wa = waLink(`Hello, I would like to book an appointment with ${doctor.name} at Mughal Gynae.`);
const callHref = doctor.phone ? `tel:${doctor.phone.replace(/[^+\d]/g, "")}` : site.phoneHref;
const profileHref = `/doctors/${doctor.slug}`;
---

<article class:list={["reveal lift group overflow-hidden rounded-2xl border border-maroon-100 bg-white hover:border-gold-400 hover:shadow-card", delay]}>
  <div class="relative aspect-[4/5] overflow-hidden bg-linear-to-br from-maroon-700 via-maroon-800 to-maroon-950">
    <div class="dot-grid absolute inset-0 opacity-20"></div>
    {doctor.image ? (
      <img src={doctor.image} alt={doctor.name} loading="lazy" class="h-full w-full object-cover object-top transition duration-700 group-hover:scale-105" />
    ) : (
      <div class="relative grid h-full place-items-center">
        <span class="grid h-28 w-28 place-items-center rounded-full bg-white/10 font-display text-4xl font-bold text-gold-200 ring-2 ring-gold-400/50 backdrop-blur-md transition duration-500 group-hover:scale-110">
          {initials(doctor.name)}
        </span>
      </div>
    )}
    {doctor.experience && (
      <span class="absolute left-4 top-4 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-maroon-700 shadow-sm">
        {doctor.experience}+ yrs
      </span>
    )}
  </div>

  <div class="p-6">
    <span class="text-[11px] font-semibold uppercase tracking-wider text-gold-700">{doctor.department}</span>
    <h3 class="mt-1.5 font-display text-xl font-bold text-ink">{doctor.name}</h3>
    <p class="text-sm font-medium text-maroon-700">{doctor.credentials}</p>
    <p class="mt-3 line-clamp-3 text-[14px] leading-relaxed text-[#6b5a61]">{doctor.bio}</p>
    <div class="mt-4 flex flex-wrap gap-1.5">
      {doctor.focus.map((f) => (
        <span class="rounded-full bg-blush px-2.5 py-1 text-[11px] font-medium text-maroon-800">{f}</span>
      ))}
    </div>
    <div class="mt-5 flex gap-2">
      <a href={profileHref} class="inline-flex flex-1 items-center justify-center gap-2 rounded-full bg-maroon-700 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-maroon-800">
        View Profile <i class="fa-solid fa-arrow-right-long text-xs"></i>
      </a>
      <a href={wa} target="_blank" rel="noopener" aria-label={`Book with ${doctor.name} on WhatsApp`} class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-[#25D366] text-white transition hover:bg-[#1ebe5b]">
        <i class="fa-brands fa-whatsapp"></i>
      </a>
      <a href={callHref} aria-label={`Call ${doctor.name}`} class="grid h-10 w-10 shrink-0 place-items-center rounded-full border border-maroon-200 text-maroon-700 transition hover:bg-maroon-700 hover:text-white">
        <i class="fa-solid fa-phone"></i>
      </a>
    </div>
  </div>
</article>
