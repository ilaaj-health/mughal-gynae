---
import { site, nav } from "../data/site";
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => (href === "/" ? path === "/" : path.startsWith(href));
---

<header id="siteHeader" class="sticky top-0 z-[100] border-b border-maroon-100 bg-cream/90 backdrop-blur-md">
  <nav class="mx-auto flex w-[92%] max-w-[1180px] items-center justify-between py-3.5">
    <a href="/" class="group flex items-center gap-3">
      <span class="grid h-11 w-11 place-items-center rounded-xl bg-linear-to-br from-maroon-700 to-maroon-900 text-gold-300 shadow-soft ring-1 ring-gold-500/30 transition-transform duration-500 group-hover:rotate-[18deg]">
        <i class="fa-solid fa-staff-snake text-lg"></i>
      </span>
      <span class="leading-tight">
        <span class="block font-display text-[19px] font-bold text-ink">Mughal <span class="text-maroon-700">Gynae</span></span>
        <span class="block text-[10px] font-semibold uppercase tracking-[.18em] text-gold-700">Medical &amp; Gynae Centre</span>
      </span>
    </a>

    <ul class="hidden items-center gap-8 lg:flex">
      {nav.map((n) => (
        <li>
          <a href={n.href} aria-current={isActive(n.href) ? "page" : undefined}
             class:list={["nav-link text-[15px] font-semibold transition hover:text-maroon-700", isActive(n.href) ? "text-maroon-700" : "text-ink"]}>
            {n.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden items-center gap-4 lg:flex">
      <a href={site.phoneHref} class="inline-flex items-center gap-2 text-[15px] font-bold text-maroon-700">
        <i class="fa-solid fa-phone-volume animate-pulse-soft"></i>{site.phoneDisplay}
      </a>
      <a href="/contact" class="shine inline-flex items-center gap-2 rounded-full bg-maroon-700 px-5 py-2.5 font-semibold text-white transition hover:-translate-y-0.5 hover:bg-maroon-800 hover:shadow-soft">
        <i class="fa-solid fa-calendar-check"></i> Book Appointment
      </a>
    </div>

    <button id="menuToggle" class="grid h-10 w-10 place-items-center rounded-lg text-xl text-maroon-800 lg:hidden" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobileMenu">
      <i class="fa-solid fa-bars"></i>
    </button>
  </nav>

  <div id="mobileMenu" class="hidden border-t border-maroon-100 bg-cream lg:hidden">
    <div class="mx-auto flex w-[92%] max-w-[1180px] flex-col py-3">
      {nav.map((n) => (
        <a href={n.href} aria-current={isActive(n.href) ? "page" : undefined}
           class="border-b border-maroon-50 py-3 font-semibold text-ink aria-[current=page]:text-maroon-700">
          {n.label}
        </a>
      ))}
      <a href="/contact" class="mt-3 inline-flex items-center justify-center gap-2 rounded-full bg-maroon-700 px-5 py-3 font-semibold text-white">
        <i class="fa-solid fa-calendar-check"></i> Book Appointment
      </a>
    </div>
  </div>
</header>
