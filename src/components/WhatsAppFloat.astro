---
import { waLink } from "../data/site";
---

<a
  href={waLink("Hello! I would like to book an appointment at Mughal Gynae.")}
  target="_blank"
  rel="noopener"
  aria-label="Chat on WhatsApp"
  class="group fixed bottom-5 right-5 z-[90] inline-flex items-center gap-2.5 rounded-full bg-[#25D366] px-5 py-3.5 font-bold text-white shadow-glow transition hover:bg-[#1ebe5b]"
>
  <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[#25D366] opacity-40"></span>
  <i class="fa-brands fa-whatsapp relative text-xl"></i>
  <span class="relative hidden sm:inline">WhatsApp</span>
</a>
