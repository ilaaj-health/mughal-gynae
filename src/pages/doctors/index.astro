---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import DoctorCard from "../../components/DoctorCard.astro";
import CTA from "../../components/CTA.astro";
import { doctors, operatingTeam, initials } from "../../data/doctors";

const gynae = doctors.filter((d) => d.department === "Gynaecology & Obstetrics");
const allied = doctors.filter((d) => d.department === "Diagnostics & General Medicine");

// Specialty filter options — data-driven from the roster
const departments = [...new Set(doctors.map((d) => d.department))];
const filters = [{ label: "All", value: "all" }, ...departments.map((d) => ({ label: d, value: d }))];
---

<Layout title="Our Doctors" description="Meet the experienced gynaecologists, radiologist and physicians at Mughal Medical & Gynae Centre, Johar Town Lahore — including a UK-trained MRCOG consultant.">
  <PageHero
    title="Our Specialists"
    crumb="Meet the Team"
    subtitle="Experienced, caring and highly qualified — our doctors are dedicated to your health and comfort."
  />

  <!-- Search + specialty filter -->
  <section class="pt-12 sm:pt-14">
    <div class="mx-auto w-[92%] max-w-[1180px]">
      <div class="flex flex-col gap-4 rounded-2xl border border-maroon-100 bg-white p-4 shadow-soft lg:flex-row lg:items-center lg:justify-between">
        <div class="relative w-full lg:max-w-xs">
          <i class="fa-solid fa-magnifying-glass pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-maroon-400"></i>
          <input
            id="docSearch"
            type="search"
            placeholder="Search doctors by name…"
            autocomplete="off"
            aria-label="Search doctors by name"
            class="w-full rounded-full border border-maroon-100 bg-cream/60 py-2.5 pl-11 pr-4 text-sm text-ink outline-none transition focus:border-gold-400 focus:bg-white"
          />
        </div>
        <div id="docFilters" class="flex flex-wrap gap-2" role="group" aria-label="Filter by specialty">
          {filters.map((f) => (
            <button
              type="button"
              data-filter={f.value}
              class:list={["doc-filter rounded-full border px-4 py-2 text-sm font-semibold transition", f.value === "all" && "is-active"]}
            >
              {f.label}
            </button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Gynaecology team -->
  <section class="py-16 sm:py-20" data-team-section>
    <div class="mx-auto w-[92%] max-w-[1180px]">
      <SectionHeading
        eyebrow="Gynaecology & Obstetrics"
        title="Women's Health Specialists"
        subtitle="Senior lady gynaecologists offering expert care across pregnancy, surgery and every women's health concern."
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {gynae.map((d, i) => (
          <DoctorCard doctor={d} delay={`d${i % 3}`} />
        ))}
      </div>
    </div>
  </section>

  <!-- Diagnostics & general medicine -->
  <section class="bg-cream py-16 sm:py-20" data-team-section>
    <div class="mx-auto w-[92%] max-w-[1180px]">
      <SectionHeading
        eyebrow="Diagnostics & General Medicine"
        title="Diagnostics & Family Care"
        subtitle="Radiology, ultrasound and general medicine alongside our specialist women's services."
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {allied.map((d, i) => (
          <DoctorCard doctor={d} delay={`d${i % 3}`} />
        ))}
      </div>
    </div>
  </section>

  <!-- No results -->
  <p id="docNoResults" class="hidden px-[4%] pb-16 text-center text-[15px] text-[#6b5a61] sm:pb-20">
    No doctors match your search.
    <button type="button" id="docClear" class="font-semibold text-maroon-700 underline underline-offset-2">Clear filters</button>
  </p>

  <!-- Operating / surgical support team -->
  {operatingTeam.length > 0 && (
    <section class="py-20 sm:py-24">
      <div class="mx-auto w-[92%] max-w-[1180px]">
        <SectionHeading
          eyebrow="Operation Theatre"
          title="Our Operating Team"
          subtitle="The skilled operation-theatre and surgical support staff who keep every procedure safe, smooth and comfortable."
        />
        <div class="mt-12 flex flex-wrap justify-center gap-6">
          {operatingTeam.map((m, i) => (
            <article class:list={["reveal lift group w-full max-w-[280px] overflow-hidden rounded-2xl border border-maroon-100 bg-white text-center hover:border-gold-400 hover:shadow-card", `d${i % 3}`]}>
              <div class="relative aspect-square overflow-hidden bg-linear-to-br from-maroon-700 via-maroon-800 to-maroon-950">
                <div class="dot-grid absolute inset-0 opacity-20"></div>
                {m.image ? (
                  <img src={m.image} alt={m.name} loading="lazy" class="h-full w-full object-cover object-top transition duration-700 group-hover:scale-105" />
                ) : (
                  <div class="relative grid h-full place-items-center">
                    <span class="grid h-24 w-24 place-items-center rounded-full bg-white/10 font-display text-3xl font-bold text-gold-200 ring-2 ring-gold-400/50 backdrop-blur-md">{initials(m.name)}</span>
                  </div>
                )}
              </div>
              <div class="p-6">
                <h3 class="font-display text-lg font-bold text-ink">{m.name}</h3>
                <p class="mt-1 text-sm font-medium text-maroon-700">{m.role}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTA title="Not sure which doctor to see?" text="Tell us your concern on WhatsApp or by phone and our team will guide you to the right specialist and a suitable appointment time." />

  <script>
    function setupDoctorDirectory() {
      const search = document.getElementById("docSearch");
      const filterWrap = document.getElementById("docFilters");
      if (!search || !filterWrap) return;

      const cards = Array.from(document.querySelectorAll(".doctor-card"));
      const sections = Array.from(document.querySelectorAll("[data-team-section]"));
      const noResults = document.getElementById("docNoResults");
      const buttons = Array.from(filterWrap.querySelectorAll(".doc-filter"));
      let activeFilter = "all";

      function setActive(value) {
        activeFilter = value;
        buttons.forEach((b) => b.classList.toggle("is-active", b.getAttribute("data-filter") === value));
      }

      function apply() {
        const q = (search instanceof HTMLInputElement ? search.value : "").trim().toLowerCase();
        let visible = 0;
        cards.forEach((card) => {
          const okDept = activeFilter === "all" || card.dataset.department === activeFilter;
          const okSearch = !q || (card.dataset.keywords || "").includes(q);
          const show = okDept && okSearch;
          card.classList.toggle("hidden", !show);
          if (show) {
            card.classList.add("in"); // ensure reveal-animated cards are visible after filtering
            visible++;
          }
        });
        sections.forEach((sec) => {
          sec.classList.toggle("hidden", !sec.querySelector(".doctor-card:not(.hidden)"));
        });
        if (noResults) noResults.classList.toggle("hidden", visible !== 0);
      }

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          setActive(btn.getAttribute("data-filter") || "all");
          apply();
        });
      });
      search.addEventListener("input", apply);

      const clear = document.getElementById("docClear");
      if (clear) clear.addEventListener("click", () => {
        if (search instanceof HTMLInputElement) search.value = "";
        setActive("all");
        apply();
      });
    }

    document.addEventListener("astro:page-load", setupDoctorDirectory);
  </script>
</Layout>
