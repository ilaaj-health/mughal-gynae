---
import Layout from "../../layouts/Layout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import DoctorCard from "../../components/DoctorCard.astro";
import CTA from "../../components/CTA.astro";
import { doctors, initials } from "../../data/doctors";
import { site, waLink } from "../../data/site";

export function getStaticPaths() {
  return doctors.map((doctor) => ({
    params: { slug: doctor.slug },
    props: { doctor },
  }));
}

const { doctor } = Astro.props;

const wa = waLink(`Hello, I would like to book an appointment with ${doctor.name} at ${site.shortName}.`);

// Other specialists in the same department (max 3) for the "related" strip.
const related = doctors
  .filter((d) => d.department === doctor.department && d.slug !== doctor.slug)
  .slice(0, 3);

const pageDescription = `${doctor.name} — ${doctor.title} (${doctor.credentials}) at ${site.name}, Johar Town Lahore. Book an appointment by phone or WhatsApp.`;

// Physician structured data (SEO), consistent with the site's MedicalClinic markup.
const physicianLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Physician",
  name: doctor.name,
  jobTitle: doctor.title,
  medicalSpecialty: doctor.department,
  description: doctor.bio,
  worksFor: { "@type": "MedicalClinic", name: site.name },
  address: {
    "@type": "PostalAddress",
    streetAddress: site.addressLine,
    addressLocality: "Johar Town, Lahore",
    addressCountry: "PK",
  },
  telephone: site.phoneDisplay,
};
if (doctor.image) {
  physicianLd.image = new URL(doctor.image, Astro.site ?? Astro.url).href;
}
---

<Layout title={doctor.name} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(physicianLd)} />

  <!-- ===== Profile hero ===== -->
  <section class="hero-bg relative overflow-hidden text-white">
    <div class="dot-grid absolute inset-0 opacity-[.12]"></div>
    <div class="pointer-events-none absolute -right-16 -top-20 h-72 w-72 rounded-full bg-gold-500/10 blur-2xl"></div>
    <div class="pointer-events-none absolute -bottom-24 left-1/4 h-72 w-72 rounded-full bg-maroon-400/15 blur-3xl"></div>

    <div class="relative mx-auto w-[92%] max-w-[1180px] py-14 sm:py-16">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-maroon-100/70" aria-label="Breadcrumb">
        <a href="/" class="transition hover:text-gold-300">Home</a>
        <i class="fa-solid fa-angle-right text-[10px] text-gold-400"></i>
        <a href="/doctors" class="transition hover:text-gold-300">Doctors</a>
        <i class="fa-solid fa-angle-right text-[10px] text-gold-400"></i>
        <span class="text-white">{doctor.name}</span>
      </nav>

      <div class="mt-10 grid items-center gap-10 lg:grid-cols-[320px_1fr]">
        <!-- Photo / avatar -->
        <div class="reveal zoom mx-auto w-full max-w-[320px]">
          <div
            class="relative aspect-[4/5] overflow-hidden rounded-3xl bg-linear-to-br from-maroon-700 via-maroon-800 to-maroon-950 shadow-glow ring-1 ring-white/15"
            style={`view-transition-name: photo-${doctor.slug}`}
          >
            <div class="dot-grid absolute inset-0 opacity-20"></div>
            {doctor.image ? (
              <img src={doctor.image} alt={doctor.name} class="h-full w-full object-cover object-top" />
            ) : (
              <div class="relative grid h-full place-items-center">
                <span class="grid h-36 w-36 place-items-center rounded-full bg-white/10 font-display text-6xl font-bold text-gold-200 ring-2 ring-gold-400/50 backdrop-blur-md">
                  {initials(doctor.name)}
                </span>
              </div>
            )}
            {doctor.experience && (
              <span class="absolute left-4 top-4 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-maroon-700 shadow-sm">
                {doctor.experience}+ yrs experience
              </span>
            )}
          </div>
        </div>

        <!-- Identity -->
        <div class="reveal right text-center lg:text-left">
          <span class="eyebrow text-gold-300">{doctor.department}</span>
          <h1 class="mt-3 font-display text-4xl font-bold text-white sm:text-5xl">{doctor.name}</h1>
          <p class="mt-3 text-lg font-medium text-gold-200">{doctor.title}</p>
          <p class="mt-1 text-[15px] text-maroon-100/85">{doctor.credentials}</p>

          <div class="mt-6 flex flex-wrap justify-center gap-2 lg:justify-start">
            {doctor.focus.map((f) => (
              <span class="rounded-full bg-white/10 px-3 py-1.5 text-[13px] font-medium text-white ring-1 ring-white/15 backdrop-blur-sm">{f}</span>
            ))}
          </div>

          <div class="mt-8 flex flex-wrap justify-center gap-3 lg:justify-start">
            <a href={wa} target="_blank" rel="noopener" class="shine inline-flex items-center gap-2.5 rounded-full bg-[#25D366] px-6 py-3 font-semibold text-white transition hover:-translate-y-0.5 hover:bg-[#1ebe5b]">
              <i class="fa-brands fa-whatsapp text-lg"></i> Book on WhatsApp
            </a>
            <a href={site.phoneHref} class="inline-flex items-center gap-2.5 rounded-full bg-white/95 px-6 py-3 font-semibold text-maroon-800 transition hover:-translate-y-0.5 hover:bg-white">
              <i class="fa-solid fa-phone"></i> Call {site.phoneDisplay}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Profile body ===== -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto grid w-[92%] max-w-[1180px] gap-10 lg:grid-cols-[1fr_360px]">
      <!-- Main -->
      <div class="reveal">
        <span class="eyebrow text-maroon-700">Profile</span>
        <div class="my-4"><span class="gold-rule"></span></div>
        <h2 class="font-display text-3xl font-bold leading-tight text-ink sm:text-4xl">About {doctor.name}</h2>
        <p class="mt-5 text-[17px] leading-relaxed text-[#6b5a61]">{doctor.bio}</p>

        <!-- Areas of focus -->
        <h3 class="mt-10 font-display text-xl font-bold text-ink">Areas of Focus</h3>
        <ul class="mt-5 grid gap-3 sm:grid-cols-2">
          {doctor.focus.map((f) => (
            <li class="flex items-start gap-3 rounded-2xl border border-maroon-100 bg-white p-4">
              <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center rounded-full bg-blush text-maroon-700">
                <i class="fa-solid fa-check text-xs"></i>
              </span>
              <span class="text-[15px] font-medium text-ink">{f}</span>
            </li>
          ))}
        </ul>

        <!-- Reassurance / consultation note (site-level facts only) -->
        <div class="mt-10 flex flex-col gap-4 rounded-3xl bg-cream p-6 sm:flex-row sm:items-center sm:justify-between sm:p-8">
          <div>
            <h3 class="font-display text-xl font-bold text-ink">Book a consultation</h3>
            <p class="mt-2 max-w-md text-[15px] leading-relaxed text-[#6b5a61]">
              Appointments are available during OPD hours ({site.hoursOpd}), with {site.hoursEmergency} emergency &amp; maternity cover.
            </p>
          </div>
          <a href={wa} target="_blank" rel="noopener" class="shine inline-flex shrink-0 items-center justify-center gap-2.5 rounded-full bg-maroon-700 px-6 py-3 font-semibold text-white transition hover:-translate-y-0.5 hover:bg-maroon-800">
            <i class="fa-brands fa-whatsapp text-lg"></i> Message us
          </a>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="reveal right lg:sticky lg:top-28 lg:self-start">
        <div class="overflow-hidden rounded-3xl border border-maroon-100 bg-white shadow-soft">
          <div class="band-maroon px-6 py-5 text-white">
            <h3 class="font-display text-lg font-bold text-white">At a glance</h3>
          </div>
          <dl class="divide-y divide-maroon-100/70 px-6">
            <div class="flex items-start gap-3 py-4">
              <i class="fa-solid fa-stethoscope mt-1 w-5 text-center text-maroon-700"></i>
              <div>
                <dt class="text-[11px] font-semibold uppercase tracking-wider text-gold-700">Department</dt>
                <dd class="text-[15px] font-medium text-ink">{doctor.department}</dd>
              </div>
            </div>
            <div class="flex items-start gap-3 py-4">
              <i class="fa-solid fa-graduation-cap mt-1 w-5 text-center text-maroon-700"></i>
              <div>
                <dt class="text-[11px] font-semibold uppercase tracking-wider text-gold-700">Qualifications</dt>
                <dd class="text-[15px] font-medium text-ink">{doctor.credentials}</dd>
              </div>
            </div>
            {doctor.experience && (
              <div class="flex items-start gap-3 py-4">
                <i class="fa-solid fa-award mt-1 w-5 text-center text-maroon-700"></i>
                <div>
                  <dt class="text-[11px] font-semibold uppercase tracking-wider text-gold-700">Experience</dt>
                  <dd class="text-[15px] font-medium text-ink">{doctor.experience}+ years</dd>
                </div>
              </div>
            )}
            <div class="flex items-start gap-3 py-4">
              <i class="fa-solid fa-clock mt-1 w-5 text-center text-maroon-700"></i>
              <div>
                <dt class="text-[11px] font-semibold uppercase tracking-wider text-gold-700">OPD Hours</dt>
                <dd class="text-[15px] font-medium text-ink">{site.hoursOpd}</dd>
              </div>
            </div>
          </dl>
          <div class="flex flex-col gap-2.5 px-6 pb-6 pt-2">
            <a href={wa} target="_blank" rel="noopener" class="shine inline-flex items-center justify-center gap-2.5 rounded-full bg-[#25D366] px-5 py-3 font-semibold text-white transition hover:bg-[#1ebe5b]">
              <i class="fa-brands fa-whatsapp text-lg"></i> Book on WhatsApp
            </a>
            <a href={site.phoneHref} class="inline-flex items-center justify-center gap-2.5 rounded-full border border-maroon-200 px-5 py-3 font-semibold text-maroon-700 transition hover:bg-maroon-700 hover:text-white">
              <i class="fa-solid fa-phone"></i> Call {site.phoneDisplay}
            </a>
          </div>
        </div>

        <a href="/doctors" class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-maroon-700 transition hover:gap-3 hover:text-maroon-800">
          <i class="fa-solid fa-arrow-left-long"></i> Back to all doctors
        </a>
      </aside>
    </div>
  </section>

  <!-- ===== Related specialists ===== -->
  {related.length > 0 && (
    <section class="bg-cream py-20 sm:py-24">
      <div class="mx-auto w-[92%] max-w-[1180px]">
        <SectionHeading
          eyebrow="Meet the Team"
          title={`Other ${doctor.department === "Gynaecology & Obstetrics" ? "Women's Health" : "Medicine & Diagnostics"} Specialists`}
          subtitle="Explore more of our experienced doctors across the same department."
        />
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((d, i) => (
            <DoctorCard doctor={d} delay={`d${i % 3}`} />
          ))}
        </div>
      </div>
    </section>
  )}

  <CTA title={`Ready to see ${doctor.name}?`} text="Send us a message on WhatsApp or call directly and our team will confirm an appointment time that suits you." />
</Layout>
