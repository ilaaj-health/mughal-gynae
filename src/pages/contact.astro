---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import AppointmentForm from "../components/AppointmentForm.astro";
import { site, waLink, mapEmbedSrc, mapDirections } from "../data/site";

const contactCards = [
  { icon: "fa-solid fa-location-dot", title: "Visit Us", lines: [site.addressLine, site.addressArea], href: mapDirections, cta: "Get Directions" },
  { icon: "fa-solid fa-phone-volume", title: "Call Us", lines: [site.phoneDisplay, "OPD: " + site.hoursOpd], href: site.phoneHref, cta: "Call Now" },
  { icon: "fa-brands fa-whatsapp", title: "WhatsApp", lines: [site.whatsappDisplay, "Quick replies, easy booking"], href: waLink("Hello! I would like to book an appointment at Mughal Gynae."), cta: "Message Us" },
  { icon: "fa-solid fa-envelope", title: "Email Us", lines: [site.email, "We reply within working hours"], href: site.emailHref, cta: "Send Email" },
];
---

<Layout title="Contact & Appointments" description="Book an appointment at Mughal Medical & Gynae Centre, Johar Town Lahore. Call, WhatsApp or send a request online. 24/7 emergency and maternity services.">
  <PageHero
    title="Contact & Appointments"
    crumb="Get In Touch"
    subtitle="Booking is easy — call, message us on WhatsApp, or send a request below and our team will confirm your appointment."
  />

  <!-- Form + hours -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto grid w-[92%] max-w-[1180px] gap-10 lg:grid-cols-[1.3fr_1fr]">
      <!-- Form -->
      <div class="reveal left rounded-3xl border border-maroon-100 bg-white p-7 shadow-soft sm:p-9">
        <span class="eyebrow text-maroon-700">Request an Appointment</span>
        <h2 class="mt-3 font-display text-2xl font-bold text-ink sm:text-3xl">Book in a Few Seconds</h2>
        <p class="mt-2 mb-6 text-[15px] text-[#6b5a61]">Fill in your details and your request opens straight in WhatsApp — quick, simple and no account needed.</p>
        <AppointmentForm />
      </div>

      <!-- Hours + emergency -->
      <div class="reveal right space-y-6">
        <div class="rounded-3xl bg-cream p-7 sm:p-8">
          <h3 class="flex items-center gap-3 font-display text-xl font-bold text-ink">
            <i class="fa-solid fa-clock text-maroon-700"></i> Opening Hours
          </h3>
          <ul class="mt-5 space-y-3 text-[15px]">
            <li class="flex items-center justify-between border-b border-maroon-100 pb-3">
              <span class="text-[#6b5a61]">OPD (Mon – Sun)</span>
              <span class="font-semibold text-ink">{site.hoursOpd}</span>
            </li>
            <li class="flex items-center justify-between border-b border-maroon-100 pb-3">
              <span class="text-[#6b5a61]">Emergency & Maternity</span>
              <span class="font-semibold text-maroon-700">24 / 7</span>
            </li>
            <li class="flex items-center justify-between">
              <span class="text-[#6b5a61]">Pharmacy</span>
              <span class="font-semibold text-maroon-700">24 / 7</span>
            </li>
          </ul>
        </div>

        <div class="overflow-hidden rounded-3xl bg-linear-to-br from-maroon-700 to-maroon-900 p-7 text-white shadow-card sm:p-8">
          <h3 class="flex items-center gap-3 font-display text-xl font-bold text-white">
            <i class="fa-solid fa-truck-medical text-gold-300"></i> 24/7 Emergency
          </h3>
          <p class="mt-3 text-[15px] text-maroon-100/85">For obstetric or medical emergencies, our team is available around the clock. Call us straight away.</p>
          <a href={site.emergencyHref} class="shine mt-5 inline-flex items-center gap-2.5 rounded-full bg-gold-500 px-6 py-3 font-semibold text-ink transition hover:bg-gold-400">
            <i class="fa-solid fa-phone"></i> {site.emergencyDisplay}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact cards -->
  <section class="pb-20 sm:pb-24">
    <div class="mx-auto grid w-[92%] max-w-[1180px] gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {contactCards.map((c, i) => (
        <a
          href={c.href}
          target={c.href.startsWith("http") ? "_blank" : undefined}
          rel={c.href.startsWith("http") ? "noopener" : undefined}
          class:list={["reveal lift group rounded-2xl border border-maroon-100 bg-white p-7 text-center hover:border-gold-400 hover:shadow-card", `d${i}`]}
        >
          <div class="mx-auto mb-4 grid h-16 w-16 place-items-center rounded-full bg-blush text-2xl text-maroon-700 transition group-hover:bg-maroon-700 group-hover:text-gold-300">
            <i class={c.icon}></i>
          </div>
          <h3 class="font-display text-lg font-bold text-ink">{c.title}</h3>
          {c.lines.map((l) => <p class="mt-1 text-[14px] text-[#6b5a61]">{l}</p>)}
          <span class="mt-3 inline-flex items-center gap-2 text-sm font-semibold text-maroon-700 transition-all group-hover:gap-3">{c.cta} <i class="fa-solid fa-arrow-right-long"></i></span>
        </a>
      ))}
    </div>
  </section>

  <!-- Map -->
  <section class="pb-20 sm:pb-24">
    <div class="mx-auto w-[92%] max-w-[1180px]">
      <SectionHeading eyebrow="Find Us" title="Visit Our Centre in Johar Town" subtitle={site.addressFull} />
      <div class="reveal mt-10 overflow-hidden rounded-3xl border border-maroon-100 shadow-card">
        <iframe
          title="Map to Mughal Medical & Gynae Centre"
          src={mapEmbedSrc}
          width="100%"
          height="440"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="block w-full"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>
