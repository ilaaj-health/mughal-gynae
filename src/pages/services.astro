---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CTA from "../components/CTA.astro";
import { services, extraServices } from "../data/services";

const steps = [
  { icon: "fa-solid fa-calendar-check", title: "Book", text: "Call or message us on WhatsApp to request a convenient appointment time." },
  { icon: "fa-solid fa-user-doctor", title: "Consult", text: "Meet your specialist for a thorough, unhurried consultation and examination." },
  { icon: "fa-solid fa-wave-square", title: "Diagnose", text: "On-site ultrasound and lab tests give clear answers without extra trips." },
  { icon: "fa-solid fa-heart-pulse", title: "Care & Follow-up", text: "Receive a clear treatment plan and ongoing support through recovery." },
];
---

<Layout title="Services" description="Gynaecology, obstetrics & maternity, deliveries, ultrasound, laboratory, family medicine and 24/7 emergency care at Mughal Medical & Gynae Centre, Johar Town Lahore.">
  <PageHero
    title="Our Services"
    crumb="What We Offer"
    subtitle="Comprehensive women's and family healthcare — expert consultation, maternity, diagnostics and surgery, all under one roof."
  />

  <!-- All services -->
  <section class="py-20 sm:py-24">
    <div class="mx-auto w-[92%] max-w-[1180px]">
      <SectionHeading eyebrow="Departments & Treatments" title="Specialist Care for Every Need" subtitle="Whatever stage of life or health concern, our team offers expert, compassionate care tailored to you." />
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {services.map((s, i) => (
          <article class:list={["reveal lift group rounded-2xl border border-maroon-100 bg-white p-7 hover:border-gold-400 hover:shadow-card", `d${i % 3}`]}>
            <div class="shine grid h-14 w-14 place-items-center rounded-xl bg-blush text-2xl text-maroon-700 transition duration-300 group-hover:bg-maroon-700 group-hover:text-gold-300">
              <i class={s.icon}></i>
            </div>
            <h3 class="mt-5 font-display text-xl font-bold text-ink">{s.title}</h3>
            <p class="mt-2.5 text-[15px] leading-relaxed text-[#6b5a61]">{s.description}</p>
            <a href="/contact" class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-maroon-700 transition-all duration-300 group-hover:gap-3">
              Book this service <i class="fa-solid fa-arrow-right-long"></i>
            </a>
          </article>
        ))}
      </div>

      <!-- Extra services -->
      <div class="reveal mt-12 rounded-3xl bg-cream p-8 text-center sm:p-10">
        <h3 class="font-display text-xl font-bold text-ink">We Also Offer</h3>
        <div class="my-4 flex justify-center"><span class="gold-rule"></span></div>
        <div class="flex flex-wrap justify-center gap-2.5">
          {extraServices.map((e) => (
            <span class="rounded-full border border-maroon-200 bg-white px-4 py-2 text-sm text-[#6b5a61] transition hover:border-gold-400 hover:text-maroon-700">{e}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="band-maroon relative overflow-hidden py-20 text-white sm:py-24">
    <div class="dot-grid absolute inset-0 opacity-10"></div>
    <div class="relative mx-auto w-[92%] max-w-[1180px]">
      <SectionHeading light eyebrow="How It Works" title="Simple, Stress-Free Care" subtitle="From first contact to follow-up, we make getting the right care easy." />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {steps.map((s, i) => (
          <div class:list={["reveal text-center", `d${i}`]}>
            <div class="relative mx-auto mb-5 grid h-20 w-20 place-items-center rounded-full bg-white/10 text-3xl text-gold-300 ring-1 ring-gold-400/30 backdrop-blur-md">
              <i class={s.icon}></i>
              <span class="absolute -right-1 -top-1 grid h-7 w-7 place-items-center rounded-full bg-gold-500 font-display text-sm font-bold text-ink">{i + 1}</span>
            </div>
            <h3 class="font-display text-lg font-bold text-white">{s.title}</h3>
            <p class="mt-2 text-[14px] leading-relaxed text-maroon-100/80">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</Layout>
