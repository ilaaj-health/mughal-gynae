---
import Layout from "../layouts/Layout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ServiceCard from "../components/ServiceCard.astro";
import DoctorCard from "../components/DoctorCard.astro";
import Stats from "../components/Stats.astro";
import Testimonials from "../components/Testimonials.astro";
import CTA from "../components/CTA.astro";
import { site, waLink } from "../data/site";
import { featuredServices } from "../data/services";
import { featuredDoctors } from "../data/doctors";

const features = [
  { icon: "fa-solid fa-venus", title: "Female Specialists", text: "Experienced, PMDC-verified lady gynaecologists for care in complete comfort and privacy." },
  { icon: "fa-solid fa-baby", title: "24/7 Maternity & Emergency", text: "Round-the-clock labour, delivery and emergency cover — we're here whenever you need us." },
  { icon: "fa-solid fa-wave-square", title: "On-Site Diagnostics", text: "Ultrasound, laboratory and pathology under one roof for faster, accurate diagnosis." },
];

const whyUs = [
  { icon: "fa-solid fa-user-nurse", title: "Experienced Lady Doctors", text: "A team of senior female gynaecologists, including a UK-trained (MRCOG) consultant." },
  { icon: "fa-solid fa-shield-heart", title: "Privacy & Comfort", text: "Discreet, respectful care in a calm, clean and welcoming environment." },
  { icon: "fa-solid fa-stethoscope", title: "Complete Care, One Roof", text: "Consultation, ultrasound, lab, delivery and pharmacy — no running between facilities." },
  { icon: "fa-solid fa-sack-dollar", title: "Affordable Fees", text: "Honest, transparent pricing with no unnecessary tests or procedures." },
  { icon: "fa-solid fa-clock", title: "Short Wait Times", text: "Easy WhatsApp booking and well-managed OPD timings that respect your day." },
  { icon: "fa-solid fa-location-dot", title: "Central Johar Town", text: "Conveniently located on P Block Road — easy to reach from across Lahore." },
];
---

<Layout>
  <!-- ===== HERO (gradient, full-width editorial) ===== -->
  <section class="hero-bg relative flex min-h-[86vh] items-center overflow-hidden text-white">
    <div class="dot-grid absolute inset-0 opacity-[.10]"></div>
    <div class="pointer-events-none absolute -left-24 -top-24 h-96 w-96 rounded-full bg-maroon-400/25 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-24 right-1/4 h-96 w-96 rounded-full bg-gold-500/15 blur-3xl"></div>

    <!-- Decorative women's-health ring motif (right) -->
    <div class="pointer-events-none absolute -right-32 top-1/2 hidden -translate-y-1/2 lg:block" aria-hidden="true">
      <div class="grid h-[36rem] w-[36rem] place-items-center rounded-full border border-gold-400/20">
        <div class="grid h-[26rem] w-[26rem] place-items-center rounded-full border border-white/10">
          <div class="grid h-[17rem] w-[17rem] place-items-center rounded-full bg-white/[.04]">
            <i class="fa-solid fa-venus text-[7rem] text-gold-300/25"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="relative mx-auto w-[92%] max-w-[1180px] py-24 lg:py-28">
      <div class="max-w-2xl">
        <span class="inline-flex items-center gap-3 text-gold-300" style="animation: fadeUp .7s ease both;">
          <span class="h-px w-10 bg-gold-400"></span>
          <span class="eyebrow">Trusted Women's Healthcare in Lahore</span>
        </span>

        <h1 class="mt-5 font-display text-5xl font-bold leading-[1.04] text-white sm:text-6xl lg:text-[68px]" style="animation: fadeUp .8s ease .12s both;">
          Caring for Women,<br />
          <span class="text-gradient-gold">at Every Stage of Life</span>
        </h1>

        <p class="mt-6 max-w-xl text-lg leading-relaxed text-maroon-100/90 sm:text-xl" style="animation: fadeUp .8s ease .28s both;">
          Expert gynaecology, safe maternity care and modern diagnostics — together under one roof in Johar Town, delivered with warmth, dignity and complete privacy.
        </p>

        <div class="mt-9 flex flex-wrap gap-4" style="animation: fadeUp .8s ease .44s both;">
          <a href="/contact" class="shine inline-flex items-center gap-2.5 rounded-full bg-gold-500 px-8 py-4 font-semibold text-ink transition hover:-translate-y-0.5 hover:bg-gold-400 hover:shadow-gold">
            <i class="fa-solid fa-calendar-check"></i> Book Appointment
          </a>
          <a href={site.phoneHref} class="inline-flex items-center gap-2.5 rounded-full bg-white/10 px-8 py-4 font-semibold text-white ring-1 ring-white/30 backdrop-blur-md transition hover:bg-white hover:text-maroon-800">
            <i class="fa-solid fa-phone"></i> {site.phoneDisplay}
          </a>
        </div>

        <!-- Elegant trust line (avatars + rating) -->
        <div class="mt-11 flex items-center gap-4" style="animation: fadeUp .8s ease .6s both;">
          <div class="flex -space-x-3">
            {["S", "M", "Z", "A"].map((c) => (
              <span class="grid h-11 w-11 place-items-center rounded-full bg-linear-to-br from-maroon-500 to-maroon-800 font-display text-sm font-bold text-gold-200 ring-2 ring-gold-400/40">{c}</span>
            ))}
          </div>
          <div class="text-sm leading-tight text-maroon-100/85">
            <div class="flex gap-0.5 text-gold-400" aria-hidden="true">
              <i class="fa-solid fa-star text-xs"></i><i class="fa-solid fa-star text-xs"></i><i class="fa-solid fa-star text-xs"></i><i class="fa-solid fa-star text-xs"></i><i class="fa-solid fa-star text-xs"></i>
            </div>
            <p class="mt-1">Cared for by <b class="text-white">senior female specialists</b></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FEATURE STRIP ===== -->
  <div class="relative z-[5] -mt-12 lg:-mt-16">
    <div class="mx-auto grid w-[92%] max-w-[1180px] gap-6 md:grid-cols-3">
      {features.map((f, i) => (
        <div class:list={["reveal zoom lift group rounded-2xl bg-white p-8 text-center shadow-soft hover:shadow-card", `d${i}`]}>
          <div class="mx-auto mb-4 grid h-[70px] w-[70px] place-items-center rounded-full bg-blush text-3xl text-maroon-700 transition duration-300 group-hover:bg-maroon-700 group-hover:text-gold-300">
            <i class={f.icon}></i>
          </div>
          <h3 class="font-display text-xl font-bold text-ink">{f.title}</h3>
          <p class="mt-2 text-[15px] leading-relaxed text-[#6b5a61]">{f.text}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- ===== ABOUT TEASER ===== -->
  <section class="py-20 sm:py-24">
    <div class="mx-auto grid w-[92%] max-w-[1180px] items-center gap-12 lg:grid-cols-2">
      <div class="reveal left relative">
        <div class="overflow-hidden rounded-3xl shadow-card">
          <img src="https://images.unsplash.com/photo-1631815588090-d4bfec5b1ccb?auto=format&fit=crop&w=900&q=80" alt="Modern, welcoming medical centre interior" class="aspect-[4/3] w-full object-cover" />
        </div>
        <div class="absolute -bottom-6 -right-3 animate-floaty rounded-2xl bg-maroon-700 px-6 py-4 text-center text-white shadow-gold">
          <span class="block font-display text-3xl font-bold leading-none text-gold-300">6+</span>
          <span class="text-xs">Specialists</span>
        </div>
        <span class="gold-rule absolute -left-3 -top-3 hidden h-16 w-16 rounded-tl-3xl border-l-2 border-t-2 border-gold-400 bg-transparent lg:block"></span>
      </div>

      <div class="reveal right">
        <span class="eyebrow text-maroon-700">About the Centre</span>
        <div class="my-4"><span class="gold-rule"></span></div>
        <h2 class="font-display text-3xl font-bold leading-tight text-ink sm:text-4xl">A Family-Focused Women's Hospital in Johar Town</h2>
        <p class="mt-4 text-[#6b5a61]">
          For families across Johar Town and greater Lahore, {site.legalName} is a trusted name in women's health. We combine experienced female specialists, modern diagnostics and round-the-clock maternity care to support women through every stage — from routine check-ups to pregnancy, surgery and beyond.
        </p>
        <ul class="mt-6 space-y-3">
          {[
            "Senior lady gynaecologists, including a UK-trained MRCOG consultant",
            "Safe normal & C-section deliveries with 24/7 cover",
            "On-site ultrasound, laboratory and pharmacy",
            "Respectful, private and patient-centred care",
          ].map((point) => (
            <li class="flex items-start gap-3 font-medium text-ink">
              <i class="fa-solid fa-circle-check mt-1 text-maroon-600"></i>{point}
            </li>
          ))}
        </ul>
        <a href="/about" class="mt-8 inline-flex items-center gap-2 rounded-full bg-maroon-700 px-7 py-3.5 font-semibold text-white transition hover:-translate-y-0.5 hover:bg-maroon-800 hover:shadow-soft">
          Learn More About Us <i class="fa-solid fa-arrow-right-long"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES TEASER ===== -->
  <section class="bg-cream py-20 sm:py-24">
    <div class="mx-auto w-[92%] max-w-[1180px]">
      <SectionHeading
        eyebrow="What We Offer"
        title="Comprehensive Women's & Family Care"
        subtitle="From everyday consultations to maternity and diagnostics — expert care designed around the needs of women and their families."
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {featuredServices.slice(0, 8).map((s, i) => (
          <ServiceCard service={s} delay={`d${i % 4}`} />
        ))}
      </div>
      <div class="reveal mt-10 text-center">
        <a href="/services" class="inline-flex items-center gap-2 rounded-full border border-maroon-300 px-7 py-3.5 font-semibold text-maroon-700 transition hover:bg-maroon-700 hover:text-white">
          View All Services <i class="fa-solid fa-arrow-right-long"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== STATS ===== -->
  <Stats />

  <!-- ===== DOCTORS TEASER ===== -->
  <section class="py-20 sm:py-24">
    <div class="mx-auto w-[92%] max-w-[1180px]">
      <SectionHeading
        eyebrow="Meet Our Specialists"
        title="Experienced Doctors You Can Trust"
        subtitle="Our team of senior female gynaecologists and physicians is dedicated to safe, compassionate and expert care."
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredDoctors.slice(0, 3).map((d, i) => (
          <DoctorCard doctor={d} delay={`d${i % 3}`} />
        ))}
      </div>
      <div class="reveal mt-10 text-center">
        <a href="/doctors" class="inline-flex items-center gap-2 rounded-full border border-maroon-300 px-7 py-3.5 font-semibold text-maroon-700 transition hover:bg-maroon-700 hover:text-white">
          View All Doctors <i class="fa-solid fa-arrow-right-long"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== WHY US ===== -->
  <section class="bg-cream py-20 sm:py-24">
    <div class="mx-auto w-[92%] max-w-[1180px]">
      <SectionHeading
        eyebrow="Why Choose Us"
        title="Why Families Trust Mughal Gynae"
        subtitle="More than a clinic — a caring partner for your family's health, built on experience, honesty and genuine attention."
      />
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {whyUs.map((w, i) => (
          <div class:list={["reveal lift rounded-2xl border-l-4 border-maroon-600 bg-white p-7 shadow-soft", `d${i % 3}`]}>
            <h3 class="flex items-center gap-3 font-display text-lg font-bold text-ink">
              <i class={`${w.icon} text-xl text-maroon-700`}></i> {w.title}
            </h3>
            <p class="mt-2.5 text-[15px] leading-relaxed text-[#6b5a61]">{w.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <Testimonials />

  <!-- ===== CTA ===== -->
  <CTA />
</Layout>
